# Backend Environment Variables Template
# Copy these to your Vercel Project Settings > Settings > Environment Variables

# === Required Environment Variables ===

# Node Environment
NODE_ENV=production

# Server Port (Vercel sets this automatically)
PORT=5001

# MongoDB Connection
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/adarsh_vidhyapeeth?retryWrites=true&w=majority

